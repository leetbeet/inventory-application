<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/style.css" />
    <link rel="stylesheet" href="/nav.css" />
    <link rel="stylesheet" href="list.css">
    <title>Categories</title>
  </head>
  <body>
    <%- include('../nav'); -%>
    <h2>Categories</h2>
    <main>
      <div>
        <% categories.forEach((category) => { %>
          <div class="category-card">
            <p>Name: <%= category.name %></p>
            <p>ID: <%= category.id %></p>
            <div class="category-buttons">
              <a href="category/<%= category.id %>/delete"><button class="del">Delete</button></a>
              <a href="category/<%= category.id %>/update"><button class="edit">Edit</button></a>
            </div>
            <a href="category/<%= category.id %>"><button class="view">View Items</button></a>
          </div>
        <% }) %>
      </div>
      <a href="category/create"><button class="add">Add Category</button></a>
    </main>
  </body>
</html>
